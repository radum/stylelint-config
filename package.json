{
  "name": "@radum/stylelint-config",
  "type": "module",
  "version": "7.5.1",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "description": "@radum Stylelint Shareable Config",
  "author": "Radu Micu",
  "license": "MIT",
  "funding": "https://github.com/sponsors/radum",
  "homepage": "https://github.com/radum/stylelint-config",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/radum/stylelint-config.git"
  },
  "bugs": {
    "url": "https://github.com/radum/stylelint-config/issues"
  },
  "keywords": [
    "stylelint-config"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "LICENSE.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown --clean --dts",
    "stub": "tsdown",
    "watch": "tsdown --watch",
    "lint:js": "eslint '**/*.js'",
    "prepack": "pnpm build",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks && skills-npm"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "stylelint": "^16.18.0"
  },
  "dependencies": {
    "@stylistic/stylelint-plugin": "^5.2.0",
    "postcss-scss": "^4.0.9",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.2.0"
  },
  "devDependencies": {
    "@auto-it/all-contributors": "^11.3.6",
    "@auto-it/first-time-contributor": "^11.3.6",
    "@auto-it/npm": "^11.3.6",
    "@auto-it/released": "^11.3.6",
    "@radum/eslint-config": "^11.0.1",
    "@stylelint-types/stylelint-order": "^8.1.1",
    "@stylelint-types/stylelint-scss": "^7.0.1",
    "@stylelint-types/stylelint-stylistic": "^5.1.0",
    "auto": "^11.3.6",
    "eslint": "^10.5.0",
    "execa": "^9.6.1",
    "lint-staged": "^17.0.8",
    "simple-git-hooks": "^2.13.1",
    "skills-npm": "^1.1.1",
    "stylelint": "^17.13.0",
    "stylelint-define-config": "^17.11.0",
    "tinyglobby": "^0.2.17",
    "tsdown": "^0.22.1",
    "tsdown-stale-guard": "^0.1.2",
    "vitest": "^4.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
